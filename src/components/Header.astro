---
const navItems = [
	{ label: "HOME", href: "/" },
	{
		label: "ABOUT",
		href: "/about/",
		children: [
			{ label: "Beliefs", href: "/about/beliefs/" },
			{ label: "Officers", href: "/about/officers/" },
			{ label: "Archive", href: "/about/history/" }
		]
	},
	{ label: "MEMBERSHIP", href: "/membership/" },
	{ label: "COMPUTER SCIENCE", href: "/computer-science/" },
	{ label: "CONFERENCES", href: "/conferences/" },
	{
		label: "JOURNAL",
		href: "/journal/",
		children: [{ label: "Journal Archives", href: "/journal/journal-archives/" }]
	},
	{ label: "JOBS", href: "/jobs/" },
	{
		label: "RESOURCES",
		href: "/resources/",
		children: [
			{ label: "Brabenec Lectureship", href: "/brabenec-lectureship/" }
		]
	},
	{ label: "CONTACT US", href: "/contact-us/" }
];

const normalizePath = (path) => path.replace(/\/$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);

const isItemActive = (item) => {
	if (normalizePath(item.href) === currentPath) {
		return true;
	}

	if (!item.children) {
		return false;
	}

	return item.children.some((child) => normalizePath(child.href) === currentPath);
};
---

<header class="site-header">
	<div class="site-header-inner">
		<a class="site-brand" href="/" aria-label="ACMS Home">
			<img src="/media/android-chrome-512x512-1.png" alt="ACMS" width="24" height="24" loading="eager" decoding="async" />
			<span>ACMS</span>
		</a>
		<nav aria-label="Main Navigation" class="site-nav">
			<ul class="site-nav-list">
				{navItems.map((item) => {
					const isActive = isItemActive(item);

					return (
						<li class={["site-nav-item", item.children ? "has-dropdown" : ""].filter(Boolean).join(" ")}>
							<a href={item.href} class={["site-nav-link", isActive ? "active" : ""].filter(Boolean).join(" ")}>
								{item.label}
								{item.children && <span class="site-nav-caret" aria-hidden="true"></span>}
							</a>
							{item.children && (
								<ul class="site-submenu" role="menu">
									{item.children.map((child) => {
										const childActive = normalizePath(child.href) === currentPath;

										return (
											<li>
												<a href={child.href} class={childActive ? "active" : ""} role="menuitem">
													{child.label}
												</a>
											</li>
										);
									})}
								</ul>
							)}
						</li>
					);
				})}
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid #dedede;
		background: #ffffff;
		position: sticky;
		top: 0;
		z-index: 30;
		box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
	}

	.site-header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.7rem 1rem;
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.site-brand {
		text-decoration: none;
		color: #2b2b2b;
		font-weight: 700;
		letter-spacing: 0.08em;
		font-size: 0.78rem;
		line-height: 1;
		font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
	}

	.site-brand img {
		width: 1.15rem;
		height: 1.15rem;
		object-fit: cover;
		border-radius: 3px;
	}

	.site-nav {
		margin-left: auto;
		overflow: visible;
		white-space: nowrap;
		scrollbar-width: none;
	}

	.site-nav-list {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.site-nav-item {
		position: relative;
	}

	.site-nav::-webkit-scrollbar {
		display: none;
	}

	.site-nav-link {
		text-decoration: none;
		color: #555555;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		font-weight: 600;
		line-height: 1;
		font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
		padding: 0.2rem 0;
		border-bottom: 1px solid transparent;
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
	}

	.site-nav-link:hover {
		color: #e91e63;
	}

	.site-nav-link.active {
		color: #e91e63;
		border-bottom-color: #e91e63;
	}

	.site-nav-caret {
		width: 0;
		height: 0;
		border-left: 3px solid transparent;
		border-right: 3px solid transparent;
		border-top: 4px solid currentColor;
		opacity: 0.9;
	}

	.site-submenu {
		position: absolute;
		top: 100%;
		left: 0;
		list-style: none;
		margin: 0;
		padding: 0.35rem 0;
		min-width: 12rem;
		background: #ffffff;
		border: 1px solid #dedede;
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
		display: none;
		z-index: 40;
	}

	.site-submenu li {
		margin: 0;
		padding: 0;
	}

	.site-submenu a {
		display: block;
		text-decoration: none;
		color: #4b5563;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		font-weight: 600;
		font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
		padding: 0.45rem 0.75rem;
	}

	.site-submenu a:hover,
	.site-submenu a.active {
		color: #e91e63;
		background: #fafafa;
	}

	.site-nav-item.has-dropdown:hover > .site-submenu,
	.site-nav-item.has-dropdown:focus-within > .site-submenu {
		display: block;
	}

	@media (max-width: 900px) {
		.site-header-inner {
			gap: 0.85rem;
			padding: 0.65rem 0.75rem;
		}

		.site-brand {
			gap: 0.35rem;
		}

		.site-brand img {
			width: 1rem;
			height: 1rem;
		}

		.site-nav {
			overflow-x: auto;
			overflow-y: visible;
		}

		.site-nav-list {
			gap: 0.75rem;
		}
	}
</style>
